// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  RESIDENT
  ADMIN
}

enum Category {
  ELECTRICAL
  PLUMBING
  SECURITY
  CLEANING
  OTHER
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED
  REOPENED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(RESIDENT)
  flatNo    String?  @map("flat_no")
  createdAt DateTime @default(now()) @map("created_at")

  complaints      Complaint[]     @relation("UserComplaints")
  statusChanges   StatusHistory[] @relation("ChangedByUser")
  notices         Notice[]        @relation("AdminNotices")

  @@map("users")
}

model Complaint {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  category    Category
  description String
  status      Status    @default(OPEN)
  priority    Priority?
  isOverdue   Boolean   @default(false) @map("is_overdue")
  createdAt   DateTime  @default(now()) @map("created_at")
  resolvedAt  DateTime? @map("resolved_at")

  user          User            @relation("UserComplaints", fields: [userId], references: [id])
  statusHistory StatusHistory[] @relation("ComplaintHistory")
  photos        ComplaintPhoto[] @relation("ComplaintPhotos")

  @@map("complaints")
}

// Normalized photo storage — one row per photo, up to 3 per complaint.
// thumbnailUrl is auto-generated by Cloudinary (c_thumb,w_200) at upload time.
// Storing both URLs here means the list view can use thumbnails without an
// extra Cloudinary API call or client-side URL manipulation.
model ComplaintPhoto {
  id           String    @id @default(uuid())
  complaintId  String    @map("complaint_id")
  url          String    // full-resolution Cloudinary URL
  thumbnailUrl String    @map("thumbnail_url") // c_thumb,w_200 variant
  position     Int       @default(0)           // order within complaint (0-based)
  createdAt    DateTime  @default(now()) @map("created_at")

  complaint Complaint @relation("ComplaintPhotos", fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_photos")
}

model StatusHistory {
  id          String   @id @default(uuid())
  complaintId String   @map("complaint_id")
  changedBy   String?  @map("changed_by")   // NULL = system-generated (auto-escalation)
  oldStatus   Status   @map("old_status")
  newStatus   Status   @map("new_status")
  note        String?
  changedAt   DateTime @default(now()) @map("changed_at")

  complaint Complaint  @relation("ComplaintHistory", fields: [complaintId], references: [id])
  admin     User?      @relation("ChangedByUser",    fields: [changedBy],   references: [id])

  @@map("status_history")
}

model Notice {
  id          String    @id @default(uuid())
  adminId     String    @map("admin_id")
  title       String
  body        String
  isImportant Boolean   @default(false) @map("is_important")
  validUntil  DateTime? @map("valid_until") // null = never expires; past = auto-hidden
  createdAt   DateTime  @default(now()) @map("created_at")

  admin User @relation("AdminNotices", fields: [adminId], references: [id])

  @@map("notices")
}

model AppConfig {
  key   String @id
  value String

  @@map("app_config")
}

// SLA matrix — one row per category+priority combination.
// priority = null means "any priority not covered by a more specific row".
// The cron resolves the most specific match: category+priority first,
// then category-only, then falls back to the global overdue_days config.
model SlaPolicy {
  id            String    @id @default(uuid())
  category      Category
  priority      Priority?           // null = default for this category
  thresholdDays Int       @map("threshold_days")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([category, priority])
  @@map("sla_policies")
}
